// Place your settings in this file to overwrite default and user settings.
{
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/*.js": { "when": "$(basename).ts" },
        "**/app/**/*.d.ts": true,
        "**/*.js.map": true
    },
    "javascript.validate.lint.missingSemicolon": "warning",
    "typescript.check.workspaceVersion": false
}